# MinerU Configuration (PDF解析服务 - 官方API)
# 官网：https://mineru.net
MINERU_API_KEY=your_mineru_api_key_here
MINERU_TIMEOUT=300

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=True

# Qwen API Configuration (通义千问)
DASHSCOPE_API_KEY=your_dashscope_api_key_here
QWEN_MODEL_NAME=qwen-turbo

# ChromaDB Configuration
CHROMA_PERSIST_DIRECTORY=./data/vector_store
CHROMA_COLLECTION_NAME=travel_destinations

# Neo4j Configuration (GraphRAG)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# Redis Configuration (Optional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Embedding Model
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# RAG Configuration
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.7

# RRF Configuration
RRF_K=60  # RRF parameter for rank fusion

# Rerank Configuration
RERANK_TOP_N=3
RERANK_MODEL=qwen-turbo

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
