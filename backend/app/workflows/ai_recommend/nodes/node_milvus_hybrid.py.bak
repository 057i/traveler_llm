п»ҝ"""
AI Recommendation Workflow - Node: Milvus Hybrid Search

MilvusеЁЈеі°жӮҺеҰ«вӮ¬з»ұгҲЈеҰӯйҗҗзҷёзҙ°з»ӢзҠІзҳ‘+з»ӢвӮ¬йҗӨ?з»®еү§вҖҳйҚ–еҪ’еҺӨй”ӣеұҪе”ҙй–®вү§RFй“»е¶…жӮҺ
"""
import asyncio
from loguru import logger
from typing import List, Dict, Any

from ..state import AIRecommendState
from app.utils.sse_utils import send_node_start, send_node_end
from config.settings import settings

FLOW_TYPE = "ai_recommend"


async def milvus_hybrid_node(state: AIRecommendState) -> AIRecommendState:
    """
    Node: MilvusеЁЈеі°жӮҺеҰ«вӮ¬з»ұ?
    йҺөСҶо”‘ж¶“еӨҺзҹҫйӘһжғ°о”‘еҰ«вӮ¬з»ұоқ®зҙ°
    1. з»ӢзҠІзҳ‘йҚҡжҲҰеҷәеҰ«вӮ¬з»ұоқ®зҙҷbge-base-zh-v1.5й”ӣеІғоҮўж¶”еӨҢжөүжөјзЎ·зҙҡ
    2. з»ӢвӮ¬йҗӨеҝ“жӮңй–Іеҝ”о—…з»ұоқ®зҙҷйҚҸжҠҪж•ӯз’Үе¶…е°®й–°е¶Ҹзҙҡ
    3. зҖ№зӮ°з¶Ӣз»®еү§вҖҳйҚ–еҪ’еҺӨй”ӣе ҹж«ҷйҗҗз‘°жӮ•зҖ№еұҪеҸҸйҚ–еҪ’еҺӨй”ӣ?
    йҗ’и·әжӮ—жқ©ж¶ңо”‘иӨ°жҺҚз«ҙйҚ–?RRFй“»е¶…жӮҺй”ӣеІғо…ёз» жҘғз–Ҷж·ҮвҖіе®і
    """
    session_id = state.get("session_id")
    query = state.get("expanded_query") or state.get("rewritten_query", state["query"])
    entities = state.get("entities", [])

    # ========== й‘әеӮңеҒЈеҜ®вӮ¬жҝ®?==========
    logger.info("=" * 80)
    logger.info("[MilvusHybrid] йҰғж®Ң Starting Milvus hybrid search")
    logger.info(f"[MilvusHybrid] Session: {session_id}")
    logger.info(f"[MilvusHybrid] Query: {query}")
    logger.info(f"[MilvusHybrid] Entities: {entities}")
    logger.info("=" * 80)

    # йҚҷжҲҰвӮ¬д№¶ode_startжөңе¬©ж¬ў
    if session_id:
        await send_node_start(
            task_id=session_id,
            flow_type=FLOW_TYPE,
            step_id="milvus_hybrid",
            step_name="еЁЈеі°жӮҺеҰ«вӮ¬з»ұ?,
            progress=30,
            message="е§қпҪ…ж№Әжқ©ж¶ңо”‘еЁЈеі°жӮҺеҰ«вӮ¬з»ұ?.."
        )

    # ========== й‘әеӮңеҒЈжҫ¶еӢӯжӮҠ ==========
    try:
        # 1. йӘһжғ°о”‘ж¶“еӨҺзҹҫеҰ«вӮ¬з»ұ?        logger.info("[MilvusHybrid] йҰғж”§ Parallel retrieving: dense + sparse + exact")

        dense_results, sparse_results, exact_results = await asyncio.gather(
            _search_dense(query),
            _search_sparse(query),
            _search_exact_match(entities)
        )

        logger.info(f"[MilvusHybrid] Dense: {len(dense_results)} results")
        logger.info(f"[MilvusHybrid] Sparse: {len(sparse_results)} results")
        logger.info(f"[MilvusHybrid] Exact: {len(exact_results)} results")

        # ========== йҺөж’іеөғйҚҳзҶ·оқҗйҚ’е——вӮ¬иү°оҮӣйҺҜ?==========
        logger.info("[MilvusHybrid] " + "=" * 60)
        logger.info("[MilvusHybrid] йҰғжҗі йҚҳзҶ·оқҗеҰ«вӮ¬з»ұгҲўзІЁйҸӢж»ҶоҮӣйҺҜе’ғзҙ°")
        logger.info("[MilvusHybrid] " + "=" * 60)

        # йҺөж’іеөғз»ӢзҠІзҳ‘еҰ«вӮ¬з»ұо”әop 5
        if dense_results:
            logger.info("[MilvusHybrid] йҰғж•ё з»ӢзҠІзҳ‘еҰ«вӮ¬з»ұ?Top 5:")
            for i, r in enumerate(dense_results[:5], start=1):
                logger.info(
                    f"  #{i}: {r.get('name', 'N/A')[:20]:20s} | "
                    f"Score={r.get('score', 0):.4f} | "
                    f"Source={r.get('source', 'N/A')}"
                )

        # йҺөж’іеөғз»ӢвӮ¬йҗӨеҝ”о—…з»ұо”әop 5
        if sparse_results:
            logger.info("[MilvusHybrid] йҰғз…ӣ з»ӢвӮ¬йҗӨеҝ”о—…з»ұ?Top 5:")
            for i, r in enumerate(sparse_results[:5], start=1):
                logger.info(
                    f"  #{i}: {r.get('name', 'N/A')[:20]:20s} | "
                    f"Score={r.get('score', 0):.4f} | "
                    f"Source={r.get('source', 'N/A')}"
                )

        # йҺөж’іеөғз»®еү§вҖҳйҚ–еҪ’еҺӨ
        if exact_results:
            logger.info("[MilvusHybrid] йҰғз…қ з»®еү§вҖҳйҚ–еҪ’еҺӨзјҒж’ҙзҒү:")
            for i, r in enumerate(exact_results, start=1):
                logger.info(
                    f"  #{i}: {r.get('name', 'N/A')[:20]:20s} | "
                    f"Score={r.get('score', 0):.4f} (з»®еү§вҖҳйҚ–еҪ’еҺӨе©ҠвҖіеһҺ) | "
                    f"Source={r.get('source', 'N/A')}"
                )

        logger.info("[MilvusHybrid] " + "=" * 60)

        # 2. иӨ°жҺҚз«ҙйҚ–?RRFй“»е¶…жӮҺ
        logger.info("[MilvusHybrid] йҰғж”ў Normalizing and fusing with RRF...")

        from app.core.rrf_client import get_rrf_engine
        rrf_engine = get_rrf_engine()

        # жөЈи·Ёж•Өжҫ¶ж°ізҹҫRRFй“»е¶…жӮҺ
        fused_results = await rrf_engine.fuse_multi_path(
            results=[dense_results, sparse_results, exact_results],
            weights=[0.4, 0.3, 0.3],  # з»ӢзҠІзҳ‘йҠҶдҪәв–ҲйҗӨеҝӢвӮ¬дҪәз°ҝзәӯоҶје°®й–°е¶ҶжҪҲй–І?            top_k=settings.MILVUS_HYBRID_TOP_K
        )

        logger.success(f"[MilvusHybrid] йүҒ?Fused {len(fused_results)} results")

        # ========== йҺөж’іеөғй“»е¶…жӮҺйҚҡеәЈж®‘йҚ’е——вӮ¬иү°оҮӣйҺҜ?==========
        logger.info("[MilvusHybrid] " + "=" * 60)
        logger.info("[MilvusHybrid] йҰғж”ў RRFй“»е¶…жӮҺйҚҡ?Top 10:")
        logger.info("[MilvusHybrid] " + "=" * 60)

        for i, r in enumerate(fused_results[:10], start=1):
            # й‘ҫеі°еҪҮз’әоҲҡз·һж·Үв„ғдј…
            path1_rank = r.get("path_1_rank", "N/A")
            path2_rank = r.get("path_2_rank", "N/A")
            path3_rank = r.get("path_3_rank", "N/A")

            logger.info(
                f"  #{i}: {r.get('name', 'N/A')[:20]:20s} | "
                f"RRF={r.get('rrf_score', 0):.6f} | "
                f"OrigScore={r.get('score', 0):.4f} | "
                f"Ranks[Dense={path1_rank}, Sparse={path2_rank}, Exact={path3_rank}]"
            )

        logger.info("[MilvusHybrid] " + "=" * 60)

        # 3. з’Ғпј„з•»зјғоҶ»дҝҠжҗҙпёјзҙҷз» вӮ¬йҚ–ж «еў—йҸҲо„Ҡзҙҡ
        confidence = _calculate_confidence(fused_results, entities)

        state["milvus_hybrid_results"] = fused_results
        state["milvus_confidence"] = confidence

        logger.success(f"[MilvusHybrid] йүҒ?Final confidence: {confidence:.3f}")

        # йҺөж’іеөғTop 3з» вӮ¬з‘•дҪ·дҝҠйҺӯ?        if fused_results:
            logger.info("[MilvusHybrid] йҰғејі Final Top 3:")
            for i, r in enumerate(fused_results[:3], start=1):
                logger.info(
                    f"  #{i}: {r.get('name', 'N/A')} | "
                    f"RRF={r.get('rrf_score', 0):.4f} | "
                    f"Source={r.get('source', 'N/A')}"
                )
        else:
            logger.warning("[MilvusHybrid] йҲҝзӢ…з¬Қ  No results after fusion")

    except Exception as e:
        logger.error(f"[MilvusHybrid] йүӮ?Search failed: {e}")
        import traceback
        traceback.print_exc()

        state["milvus_hybrid_results"] = []
        state["milvus_confidence"] = 0.0

    # ========== й‘әеӮңеҒЈзјҒж’ҙжҪ« ==========
    logger.info("=" * 80)
    logger.success("[MilvusHybrid] йүҒ?Milvus hybrid node completed")
    logger.info("=" * 80)

    # йҚҷжҲҰвӮ¬д№¶ode_endжөңе¬©ж¬ў
    if session_id:
        await send_node_end(
            task_id=session_id,
            flow_type=FLOW_TYPE,
            step_id="milvus_hybrid",
            step_name="еЁЈеі°жӮҺеҰ«вӮ¬з»ұ?,
            progress=30,
            message=f"еЁЈеі°жӮҺеҰ«вӮ¬з»ұгҲ з•¬йҺҙ? {len(state['milvus_hybrid_results'])}йҸүпј„зІЁйҸӢ?
        )

    return state


async def _search_dense(query: str) -> List[Dict[str, Any]]:
    """з»ӢзҠІзҳ‘йҚҡжҲҰеҷәеҰ«вӮ¬з»ұоқ®зҙҷHNSWз»ұгҲ зҙ©й”ӣ?""
    try:
        from app.core.milvus_hybrid_client import get_milvus_hybrid_client
        from app.core.embedding_service import get_embedding_service

        embedding_service = get_embedding_service()
        milvus_client = get_milvus_hybrid_client()

        # йҗўзҶёеһҡз»ӢзҠІзҳ‘йҚҡжҲҰеҷә
        dense_vector = embedding_service.encode(query, normalize_embeddings=True)

        # з»ӢзҠІзҳ‘еҰ«вӮ¬з»ұ?        results = await milvus_client._search_dense(
            dense_vector,
            top_k=settings.MILVUS_DENSE_TOP_K
        )

        return results

    except Exception as e:
        logger.error(f"[MilvusHybrid] Dense search failed: {e}")
        return []


async def _search_sparse(query: str) -> List[Dict[str, Any]]:
    """з»ӢвӮ¬йҗӨеҝ“жӮңй–Іеҝ”о—…з»ұоқ®зҙҷйҚҸжҠҪж•ӯз’Үе¶…е°®й–°е¶Ҹзҙҡ"""
    try:
        from app.core.milvus_hybrid_client import get_milvus_hybrid_client

        milvus_client = get_milvus_hybrid_client()

        # з»ӢвӮ¬йҗӨеҝ”о—…з»ұ?        results = await milvus_client._search_sparse(
            query,
            top_k=settings.MILVUS_SPARSE_TOP_K
        )

        return results

    except Exception as e:
        logger.error(f"[MilvusHybrid] Sparse search failed: {e}")
        return []


async def _search_exact_match(entities: List[str]) -> List[Dict[str, Any]]:
    """зҖ№зӮ°з¶Ӣз»®еү§вҖҳйҚ–еҪ’еҺӨеҰ«вӮ¬з»ұ?""
    if not entities:
        logger.info("[MilvusHybrid] No entities for exact match")
        return []

    try:
        from app.core.milvus_hybrid_client import get_milvus_hybrid_client

        milvus_client = get_milvus_hybrid_client()

        # з»®еү§вҖҳйҚ–еҪ’еҺӨйҸҢгғЁоҮ—
        results = []
        for entity in entities[:3]:  # йҸҲвӮ¬жҫ¶ж°ӯз…Ўз’Ү?ж¶“оҒ„з–„жөЈ?            entity_results = milvus_client.collection.query(
                expr=f'name == "{entity}"',
                output_fields=["destination_id", "name", "province", "city",
                              "category", "description", "full_text", "rating"],
                limit=settings.MILVUS_EXACT_MATCH_TOP_K
            )

            # йҸҚз…ҺзҙЎйҚ–ж «зІЁйҸӢж»җзҙҷз»®еү§вҖҳйҚ–еҪ’еҺӨзјҒж¬җеј§йҚ’е—ӯзҙҡ
            for r in entity_results:
                results.append({
                    "destination_id": r.get("destination_id"),
                    "name": r.get("name"),
                    "province": r.get("province"),
                    "city": r.get("city"),
                    "category": r.get("category"),
                    "description": r.get("description"),
                    "content": r.get("full_text"),
                    "rating": r.get("rating"),
                    "score": 1.0,  # з»®еү§вҖҳйҚ–еҪ’еҺӨе©ҠвҖіеһҺ
                    "source": "exact_match"
                })

        logger.info(f"[MilvusHybrid] Exact match: {len(results)} results")
        return results

    except Exception as e:
        logger.error(f"[MilvusHybrid] Exact match failed: {e}")
        return []



def _calculate_confidence(results: List[Dict[str, Any]], entities: List[str]) -> float:
    """
    и®Ўз®—зҪ®дҝЎеәҰеҲҶж•°пјҲз®ҖеҢ–зүҲпјү

    еҹәдәҺ3дёӘеӣ зҙ пјҡ
    1. зІҫзЎ®еҢ№й…ҚпјҲ50%жқғйҮҚпјү
    2. з»“жһңж•°йҮҸпјҲ30%жқғйҮҚпјү
    3. жқҘжәҗеӨҡж ·жҖ§пјҲ20%жқғйҮҚпјү
    """
    if not results:
        return 0.0

    confidence = 0.0

    # ========== 1. зІҫзЎ®еҢ№й…ҚжЈҖжҹҘпјҲжқғйҮҚжңҖй«ҳпјү==========
    has_exact_match = False
    exact_match_rank = None

    for i, r in enumerate(results, start=1):
        if r.get("source") == "exact_match":
            has_exact_match = True
            exact_match_rank = i
            break

    if has_exact_match:
        if exact_match_rank == 1:
            confidence += 0.5  # Top1зІҫзЎ®еҢ№й…ҚпјҢж»ЎеҲҶ
        elif exact_match_rank <= 3:
            confidence += 0.4  # Top3зІҫзЎ®еҢ№й…Қ
        else:
            confidence += 0.3  # жңүзІҫзЎ®еҢ№й…ҚдҪҶжҺ’еҗҚйқ еҗҺ
    else:
        confidence += 0.1  # ж— зІҫзЎ®еҢ№й…Қ

    # ========== 2. з»“жһңж•°йҮҸ ==========
    result_count = len(results)

    if result_count >= 10:
        confidence += 0.3  # з»“жһңе……и¶і
    elif result_count >= 5:
        confidence += 0.2  # з»“жһңдёӯзӯү
    elif result_count >= 3:
        confidence += 0.15  # з»“жһңиҫғе°‘
    else:
        confidence += 0.1  # з»“жһңеҫҲе°‘

    # ========== 3. жқҘжәҗеӨҡж ·жҖ§ ==========
    sources = set(r.get("source", "") for r in results[:10])
    diversity = len(sources)

    if diversity >= 3:
        confidence += 0.2  # дёүз§ҚжқҘжәҗпјҲжңҖдҪіпјү
    elif diversity == 2:
        confidence += 0.15  # дёӨз§ҚжқҘжәҗ
    else:
        confidence += 0.1  # еҚ•дёҖжқҘжәҗ

    # еҪ’дёҖеҢ–еҲ°[0, 1]
    confidence = max(0.0, min(1.0, confidence))

    logger.info(f"[MilvusHybrid] зҪ®дҝЎеәҰи®Ўз®—: зІҫзЎ®еҢ№й…Қ={has_exact_match}, з»“жһңж•°={result_count}, жқҘжәҗж•°={diversity} вҶ’ {confidence:.3f}")

    return confidence
